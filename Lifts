<!DOCTYPE html>

<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0"/>
<title>Lift Tracker</title>
<link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@400;600;700;900&family=Barlow:wght@400;500;600&display=swap" rel="stylesheet"/>
<style>
  :root {
    --bg: #0a0a0a;
    --surface: #111111;
    --surface2: #1a1a1a;
    --border: #2a2a2a;
    --accent: #e8ff00;
    --accent2: #ff4d00;
    --text: #f0f0f0;
    --muted: #666;
    --squat: #e8ff00;
    --bench: #00d4ff;
    --deadlift: #ff4d00;
    --ohp: #b388ff;
  }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body {
    background: var(--bg);
    color: var(--text);
    font-family: 'Barlow', sans-serif;
    min-height: 100vh;
    padding-bottom: 80px;
  }
  header {
    background: var(--surface);
    border-bottom: 2px solid var(--accent);
    padding: 16px 20px;
    position: sticky; top: 0; z-index: 100;
    display: flex; align-items: center; justify-content: space-between;
  }
  header h1 {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 900;
    font-size: 1.6rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }
  header h1 span { color: var(--accent); }
  .tabs {
    display: flex;
    background: var(--surface);
    border-bottom: 1px solid var(--border);
    overflow-x: auto;
    scrollbar-width: none;
  }
  .tabs::-webkit-scrollbar { display: none; }
  .tab {
    flex: 1; min-width: 80px;
    padding: 14px 8px;
    text-align: center;
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 700;
    font-size: 0.85rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--muted);
    cursor: pointer;
    border-bottom: 3px solid transparent;
    transition: all 0.2s;
    white-space: nowrap;
  }
  .tab.active { color: var(--accent); border-bottom-color: var(--accent); }
  .page { display: none; padding: 20px; }
  .page.active { display: block; }

/* LOG PAGE */
.lift-card {
background: var(–surface);
border: 1px solid var(–border);
border-radius: 8px;
padding: 16px;
margin-bottom: 12px;
}
.lift-card-header {
display: flex; align-items: center; justify-content: space-between;
margin-bottom: 12px;
}
.lift-name {
font-family: ‘Barlow Condensed’, sans-serif;
font-weight: 700; font-size: 1.1rem;
letter-spacing: 0.05em; text-transform: uppercase;
}
.lift-dot {
width: 10px; height: 10px; border-radius: 50%; margin-right: 8px; display: inline-block;
}
.last-set { font-size: 0.75rem; color: var(–muted); }
.input-row { display: flex; gap: 8px; align-items: center; }
.input-group { flex: 1; }
.input-group label { font-size: 0.7rem; color: var(–muted); letter-spacing: 0.05em; text-transform: uppercase; display: block; margin-bottom: 4px; }
.input-group input {
width: 100%;
background: var(–surface2);
border: 1px solid var(–border);
border-radius: 6px;
padding: 10px 12px;
color: var(–text);
font-family: ‘Barlow Condensed’, sans-serif;
font-size: 1.1rem;
font-weight: 600;
text-align: center;
}
.input-group input:focus { outline: none; border-color: var(–accent); }
.log-btn {
background: var(–accent);
color: #000;
border: none;
border-radius: 6px;
padding: 10px 16px;
font-family: ‘Barlow Condensed’, sans-serif;
font-weight: 700;
font-size: 0.95rem;
letter-spacing: 0.05em;
text-transform: uppercase;
cursor: pointer;
margin-top: 18px;
align-self: flex-end;
white-space: nowrap;
}
.log-btn:active { transform: scale(0.97); }
.date-row {
display: flex; align-items: center; gap: 10px; margin-bottom: 16px;
}
.date-row label { font-size: 0.75rem; color: var(–muted); text-transform: uppercase; letter-spacing: 0.05em; }
.date-row input {
background: var(–surface2); border: 1px solid var(–border); border-radius: 6px;
padding: 8px 12px; color: var(–text); font-family: ‘Barlow’, sans-serif; font-size: 0.9rem;
}
.date-row input:focus { outline: none; border-color: var(–accent); }
.toast {
position: fixed; bottom: 90px; left: 50%; transform: translateX(-50%);
background: var(–accent); color: #000;
font-family: ‘Barlow Condensed’, sans-serif; font-weight: 700;
padding: 10px 24px; border-radius: 30px; font-size: 0.95rem;
letter-spacing: 0.05em; text-transform: uppercase;
opacity: 0; transition: opacity 0.3s; pointer-events: none; z-index: 999;
}
.toast.show { opacity: 1; }

/* PROGRESS PAGE */
.lift-filter {
display: flex; gap: 8px; margin-bottom: 16px; flex-wrap: wrap;
}
.filter-btn {
padding: 6px 14px;
border-radius: 20px;
border: 1px solid var(–border);
background: var(–surface);
color: var(–muted);
font-family: ‘Barlow Condensed’, sans-serif;
font-weight: 700; font-size: 0.8rem;
letter-spacing: 0.05em; text-transform: uppercase;
cursor: pointer;
}
.filter-btn.active { background: var(–surface2); color: var(–text); border-color: var(–text); }
.filter-btn[data-lift=“Squat”].active { border-color: var(–squat); color: var(–squat); }
.filter-btn[data-lift=“Bench”].active { border-color: var(–bench); color: var(–bench); }
.filter-btn[data-lift=“Deadlift”].active { border-color: var(–deadlift); color: var(–deadlift); }
.filter-btn[data-lift=“OHP”].active { border-color: var(–ohp); color: var(–ohp); }

canvas { width: 100% !important; }
.chart-wrap {
background: var(–surface); border: 1px solid var(–border);
border-radius: 8px; padding: 16px; margin-bottom: 16px;
}
.chart-title {
font-family: ‘Barlow Condensed’, sans-serif;
font-weight: 700; font-size: 1rem;
letter-spacing: 0.05em; text-transform: uppercase;
margin-bottom: 12px; color: var(–muted);
}
.pr-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin-bottom: 16px; }
.pr-card {
background: var(–surface); border: 1px solid var(–border);
border-radius: 8px; padding: 14px;
}
.pr-label { font-size: 0.7rem; color: var(–muted); letter-spacing: 0.08em; text-transform: uppercase; margin-bottom: 4px; }
.pr-value { font-family: ‘Barlow Condensed’, sans-serif; font-weight: 900; font-size: 1.8rem; }
.pr-sub { font-size: 0.75rem; color: var(–muted); }

/* HISTORY PAGE */
.history-filters { display: flex; gap: 8px; margin-bottom: 16px; flex-wrap: wrap; }
.history-entry {
background: var(–surface); border: 1px solid var(–border);
border-radius: 8px; padding: 14px 16px; margin-bottom: 8px;
display: flex; align-items: center; justify-content: space-between;
}
.history-left { display: flex; align-items: center; gap: 10px; }
.history-lift { font-family: ‘Barlow Condensed’, sans-serif; font-weight: 700; font-size: 1rem; text-transform: uppercase; letter-spacing: 0.05em; }
.history-date { font-size: 0.75rem; color: var(–muted); }
.history-right { text-align: right; }
.history-weight { font-family: ‘Barlow Condensed’, sans-serif; font-weight: 900; font-size: 1.3rem; }
.history-reps { font-size: 0.75rem; color: var(–muted); }
.delete-btn {
background: none; border: none; color: var(–muted); cursor: pointer;
font-size: 1.1rem; padding: 4px 8px; border-radius: 4px;
}
.delete-btn:hover { color: var(–accent2); }
.section-label {
font-family: ‘Barlow Condensed’, sans-serif;
font-weight: 700; font-size: 0.75rem;
letter-spacing: 0.1em; text-transform: uppercase;
color: var(–muted); margin: 16px 0 8px;
}
.empty-state { text-align: center; padding: 40px 20px; color: var(–muted); }
</style>

</head>
<body>

<header>
  <h1>LIFT<span>LOG</span></h1>
  <span style="font-size:0.75rem;color:var(--muted);font-family:'Barlow Condensed',sans-serif;letter-spacing:0.1em;">YOUR DATA</span>
</header>

<div class="tabs">
  <div class="tab active" onclick="showPage('log')">Log</div>
  <div class="tab" onclick="showPage('progress')">Progress</div>
  <div class="tab" onclick="showPage('history')">History</div>
</div>

<!-- LOG PAGE -->

<div id="page-log" class="page active">
  <div class="date-row">
    <label>Date</label>
    <input type="date" id="log-date"/>
  </div>
  <div id="lift-cards"></div>
</div>

<!-- PROGRESS PAGE -->

<div id="page-progress" class="page">
  <div class="pr-grid" id="pr-grid"></div>
  <div class="lift-filter" id="chart-filter"></div>
  <div class="chart-wrap">
    <div class="chart-title">Weight Over Time</div>
    <canvas id="progressChart" height="220"></canvas>
  </div>
</div>

<!-- HISTORY PAGE -->

<div id="page-history" class="page">
  <div class="history-filters" id="history-filter"></div>
  <div id="history-list"></div>
</div>

<div class="toast" id="toast">Logged!</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.0/chart.umd.min.js"></script>

<script>
const LIFTS = [
  { name: 'Squat', color: '#e8ff00' },
  { name: 'Bench', color: '#00d4ff' },
  { name: 'Deadlift', color: '#ff4d00' },
  { name: 'OHP', color: '#b388ff' },
];

const SEED_DATA = [
  {date:'2026-02-09',lift:'Squat',weight:275,reps:5},
  {date:'2026-02-09',lift:'Bench',weight:195,reps:5},
  {date:'2026-02-10',lift:'Deadlift',weight:295,reps:3},
  {date:'2026-02-10',lift:'OHP',weight:135,reps:5},
  {date:'2026-02-16',lift:'Squat',weight:285,reps:4},
  {date:'2026-02-16',lift:'Bench',weight:205,reps:5},
  {date:'2026-02-17',lift:'Deadlift',weight:295,reps:4},
  {date:'2026-02-17',lift:'OHP',weight:135,reps:3},
  {date:'2026-02-22',lift:'Squat',weight:285,reps:5},
  {date:'2026-02-22',lift:'Bench',weight:210,reps:5},
  {date:'2026-02-23',lift:'Deadlift',weight:295,reps:5},
  {date:'2026-02-23',lift:'OHP',weight:115,reps:5},
  {date:'2026-03-03',lift:'Bench',weight:215,reps:5},
  {date:'2026-03-05',lift:'Deadlift',weight:315,reps:4},
  {date:'2026-03-05',lift:'OHP',weight:115,reps:6},
  {date:'2026-03-08',lift:'Squat',weight:285,reps:5},
  {date:'2026-03-08',lift:'Bench',weight:220,reps:5},
  {date:'2026-03-09',lift:'Deadlift',weight:295,reps:1},
  {date:'2026-03-09',lift:'OHP',weight:120,reps:5},
  {date:'2026-03-15',lift:'Squat',weight:295,reps:3},
  {date:'2026-03-15',lift:'Bench',weight:225,reps:5},
  {date:'2026-03-17',lift:'Deadlift',weight:315,reps:2},
  {date:'2026-03-17',lift:'OHP',weight:125,reps:6},
  {date:'2026-03-30',lift:'Squat',weight:295,reps:3},
  {date:'2026-03-30',lift:'Bench',weight:225,reps:4},
];

function loadData() {
  const stored = localStorage.getItem('liftlog');
  if (!stored) {
    localStorage.setItem('liftlog', JSON.stringify(SEED_DATA));
    return SEED_DATA;
  }
  return JSON.parse(stored);
}
function saveData(d) { localStorage.setItem('liftlog', JSON.stringify(d)); }

let data = loadData();
let activeChartLift = 'Squat';
let activeHistoryLift = 'All';
let chartInstance = null;

// SET DATE DEFAULT
document.getElementById('log-date').value = new Date().toISOString().split('T')[0];

function liftColor(name) { return LIFTS.find(l=>l.name===name)?.color || '#fff'; }

// BUILD LOG CARDS
function buildLogCards() {
  const container = document.getElementById('lift-cards');
  container.innerHTML = '';
  LIFTS.forEach(lift => {
    const last = [...data].reverse().find(d=>d.lift===lift.name);
    const card = document.createElement('div');
    card.className = 'lift-card';
    card.innerHTML = `
      <div class="lift-card-header">
        <div style="display:flex;align-items:center">
          <span class="lift-dot" style="background:${lift.color}"></span>
          <span class="lift-name">${lift.name}</span>
        </div>
        <span class="last-set">${last ? `Last: ${last.weight}lbs × ${last.reps}` : 'No data'}</span>
      </div>
      <div class="input-row">
        <div class="input-group">
          <label>Weight (lbs)</label>
          <input type="number" id="w-${lift.name}" placeholder="${last?last.weight:''}" inputmode="decimal"/>
        </div>
        <div class="input-group">
          <label>Reps</label>
          <input type="number" id="r-${lift.name}" placeholder="${last?last.reps:''}" inputmode="numeric"/>
        </div>
        <button class="log-btn" onclick="logLift('${lift.name}')">+LOG</button>
      </div>
    `;
    container.appendChild(card);
  });
}

function logLift(liftName) {
  const date = document.getElementById('log-date').value;
  const w = parseFloat(document.getElementById(`w-${liftName}`).value);
  const r = parseInt(document.getElementById(`r-${liftName}`).value);
  if (!date || !w || !r) return;
  data.push({date, lift:liftName, weight:w, reps:r});
  data.sort((a,b)=>a.date.localeCompare(b.date));
  saveData(data);
  document.getElementById(`w-${liftName}`).value = '';
  document.getElementById(`r-${liftName}`).value = '';
  showToast(`${liftName} logged!`);
  buildLogCards();
  if(document.getElementById('page-progress').classList.contains('active')) buildProgress();
  if(document.getElementById('page-history').classList.contains('active')) buildHistory();
}

function showToast(msg) {
  const t = document.getElementById('toast');
  t.textContent = msg; t.classList.add('show');
  setTimeout(()=>t.classList.remove('show'), 1800);
}

// PROGRESS
function buildProgress() {
  // PRs
  const grid = document.getElementById('pr-grid');
  grid.innerHTML = '';
  LIFTS.forEach(lift => {
    const entries = data.filter(d=>d.lift===lift.name);
    const pr = entries.length ? Math.max(...entries.map(e=>e.weight)) : 0;
    const prEntry = entries.find(e=>e.weight===pr);
    grid.innerHTML += `
      <div class="pr-card">
        <div class="pr-label" style="color:${lift.color}">${lift.name}</div>
        <div class="pr-value" style="color:${lift.color}">${pr}<span style="font-size:1rem;font-weight:400"> lbs</span></div>
        <div class="pr-sub">${prEntry ? `${prEntry.reps} reps · ${fmtDate(prEntry.date)}` : '—'}</div>
      </div>`;
  });

  // Filter buttons
  const filterDiv = document.getElementById('chart-filter');
  filterDiv.innerHTML = '';
  LIFTS.forEach(lift => {
    const btn = document.createElement('button');
    btn.className = 'filter-btn' + (activeChartLift===lift.name?' active':'');
    btn.dataset.lift = lift.name;
    btn.textContent = lift.name;
    btn.onclick = () => { activeChartLift = lift.name; buildProgress(); };
    filterDiv.appendChild(btn);
  });

  // Chart
  const entries = data.filter(d=>d.lift===activeChartLift).map(d=>({x:d.date,y:d.weight}));
  const color = liftColor(activeChartLift);
  const ctx = document.getElementById('progressChart').getContext('2d');
  if (chartInstance) chartInstance.destroy();
  chartInstance = new Chart(ctx, {
    type: 'line',
    data: {
      datasets: [{
        data: entries,
        borderColor: color,
        backgroundColor: color + '22',
        pointBackgroundColor: color,
        pointRadius: 5,
        tension: 0.3,
        fill: true,
      }]
    },
    options: {
      parsing: { xAxisKey: 'x', yAxisKey: 'y' },
      plugins: { legend: { display: false } },
      scales: {
        x: {
          type: 'category',
          ticks: { color: '#666', font: { family: 'Barlow Condensed', size: 11 }, maxRotation: 45 },
          grid: { color: '#1f1f1f' }
        },
        y: {
          ticks: { color: '#666', font: { family: 'Barlow Condensed', size: 12 } },
          grid: { color: '#1f1f1f' }
        }
      }
    }
  });
}

// HISTORY
function buildHistory() {
  const filterDiv = document.getElementById('history-filter');
  filterDiv.innerHTML = '';
  ['All', ...LIFTS.map(l=>l.name)].forEach(name => {
    const btn = document.createElement('button');
    btn.className = 'filter-btn' + (activeHistoryLift===name?' active':'');
    btn.dataset.lift = name;
    btn.textContent = name;
    btn.onclick = () => { activeHistoryLift = name; buildHistory(); };
    filterDiv.appendChild(btn);
  });

  const list = document.getElementById('history-list');
  list.innerHTML = '';
  const filtered = activeHistoryLift==='All' ? [...data] : data.filter(d=>d.lift===activeHistoryLift);
  const sorted = [...filtered].reverse();

  if (!sorted.length) { list.innerHTML = '<div class="empty-state">No entries yet</div>'; return; }

  let lastDate = '';
  sorted.forEach((entry, idx) => {
    if (entry.date !== lastDate) {
      const label = document.createElement('div');
      label.className = 'section-label';
      label.textContent = fmtDate(entry.date);
      list.appendChild(label);
      lastDate = entry.date;
    }
    const color = liftColor(entry.lift);
    const div = document.createElement('div');
    div.className = 'history-entry';
    div.innerHTML = `
      <div class="history-left">
        <span class="lift-dot" style="background:${color}"></span>
        <div>
          <div class="history-lift" style="color:${color}">${entry.lift}</div>
        </div>
      </div>
      <div style="display:flex;align-items:center;gap:12px">
        <div class="history-right">
          <div class="history-weight">${entry.weight} <span style="font-size:0.8rem;font-weight:400;color:var(--muted)">lbs</span></div>
          <div class="history-reps">${entry.reps} reps</div>
        </div>
        <button class="delete-btn" onclick="deleteEntry(${data.indexOf(entry)})">✕</button>
      </div>`;
    list.appendChild(div);
  });
}

function deleteEntry(idx) {
  if (!confirm('Delete this entry?')) return;
  data.splice(idx, 1);
  saveData(data);
  buildLogCards();
  buildHistory();
  if(document.getElementById('page-progress').classList.contains('active')) buildProgress();
}

function fmtDate(d) {
  const [y,m,day] = d.split('-');
  return new Date(y,m-1,day).toLocaleDateString('en-US',{month:'short',day:'numeric'});
}

function showPage(name) {
  document.querySelectorAll('.page').forEach(p=>p.classList.remove('active'));
  document.querySelectorAll('.tab').forEach(t=>t.classList.remove('active'));
  document.getElementById('page-'+name).classList.add('active');
  document.querySelectorAll('.tab').forEach(t=>{ if(t.textContent.toLowerCase()===name) t.classList.add('active'); });
  if (name==='progress') buildProgress();
  if (name==='history') buildHistory();
}

buildLogCards();
</script>

</body>
</html>
